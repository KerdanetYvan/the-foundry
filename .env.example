# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/foundry

# App
APP_URL=https://your-domain.com
SESSION_SECRET=change_me_in_production
SERVER_ADDRESS=your-mc-server.com

# Minecraft RCON connection
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password

# Chemins Minecraft (valeurs par défaut pour la prod avec /host/root monté)
# MC_LOG_PATH=/host/root/opt/minecraft/minecraft/data/logs/latest.log
# MC_MODS_PATH=/host/root/opt/minecraft/minecraft/data/mods
